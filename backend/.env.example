# Application
APP_NAME="AI Face Recognition Attendance System"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=attendance_db
DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/attendance_db

# JWT
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg

# Face Recognition
FACE_RECOGNITION_TOLERANCE=0.5
MIN_FACE_IMAGES=1
MAX_FACE_IMAGES=10

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Admin defaults
DEFAULT_ADMIN_EMAIL=admin@attendance.com
DEFAULT_ADMIN_PASSWORD=Admin@123456
DEFAULT_ADMIN_NAME=System Admin
